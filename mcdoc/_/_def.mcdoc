use ::delay::mcdoc::def::Command
use ::delay::mcdoc::def::Uuid

struct VariableRegister {
    [string]: any
}
dispatch minecraft:storage[delay:_] to struct {
    /// top level
    t: VariableRegister,
    /// impl
    v: VariableRegister,
    /// util
    u: VariableRegister,
    /// in-scope temp
    x: VariableRegister,
}
dispatch minecraft:storage[delay:_/in] to struct {
    [any]: any
}
dispatch minecraft:storage[delay:_/out] to struct {
    [any]: any
}
